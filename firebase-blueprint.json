{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "ffUid": { "type": "string" },
        "ffIgn": { "type": "string" },
        "teamName": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "isBanned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Tournament": {
      "title": "Tournament",
      "description": "Tournament details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "entryFee": { "type": "number" },
        "mode": { "type": "string", "enum": ["Solo", "Duo", "Squad"] },
        "totalSlots": { "type": "integer" },
        "filledSlots": { "type": "integer" },
        "prizePool": { "type": "string" },
        "rules": { "type": "string" },
        "roomId": { "type": "string" },
        "roomPassword": { "type": "string" },
        "status": { "type": "string", "enum": ["upcoming", "live", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "date", "time", "entryFee", "mode", "totalSlots", "status"]
    },
    "Registration": {
      "title": "Registration",
      "description": "Tournament registration record",
      "type": "object",
      "properties": {
        "tournamentId": { "type": "string" },
        "userId": { "type": "string" },
        "playerName": { "type": "string" },
        "ffUid": { "type": "string" },
        "ffIgn": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "teamName": { "type": "string" },
        "paymentScreenshotUrl": { "type": "string" },
        "transactionId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tournamentId", "userId", "playerName", "ffUid", "ffIgn", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Public announcements",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Available tournaments"
    },
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Tournament registrations"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Public announcements"
    }
  }
}
